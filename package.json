{
  "name": "mediaharbor",
  "version": "1.1.9",
  "scripts": {
    "postinstall": "node scripts/patch-librespot.js",
    "dev": "vite",
    "build:react": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint . --report-unused-disable-directives --max-warnings 0",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "test": "vitest",
    "tauri:icon": "npx tauri icon D:/Documents/MH-WEB/SVG/MHLogo.svg -o src/app/icons",
    "tauri:dev": "concurrently \"npx vite dev\" \"cd src/app && cargo tauri dev\"",
    "tauri:build": "npm run build:react && cd src/app && APPIMAGE_EXTRACT_AND_RUN=1 cargo tauri build",
    "tauri:build:linux": "npm run build:react && cd src/app && APPIMAGE_EXTRACT_AND_RUN=1 cargo tauri build --bundles deb,rpm,appimage",
    "tauri:build:win": "npm run build:react && cd src/app && cargo tauri build --bundles msi,nsis",
    "tauri:build:mac": "npm run build:react && cd src/app && cargo tauri build --bundles dmg,app",
    "tauri:build:mac:x64": "npm run build:react && cd src/app && cargo tauri build --target x86_64-apple-darwin --bundles dmg",
    "tauri:build:mac:arm64": "npm run build:react && cd src/app && cargo tauri build --target aarch64-apple-darwin --bundles dmg"
  },
  "keywords": [],
  "author": "CrossyAtom46",
  "license": "GPL-3.0-or-later",
  "description": "MediaHarbor",
  "homepage": "https://mediaharbor.github.io",
  "devDependencies": {
    "@tauri-apps/cli": "^2.10.1",
    "@types/node": "^20.11.5",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@unocss/preset-icons": "^66.5.3",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.17",
    "concurrently": "^8.2.2",
    "cross-env": "^10.1.0",
    "eslint": "^9.0.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "globals": "^15.0.0",
    "postcss": "^8.4.33",
    "prettier": "^3.2.4",
    "tailwindcss": "^3.4.1",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.3.3",
    "vite": "^6.1.7",
    "vitest": "^3.0.0",
    "wait-on": "^7.2.0"
  },
  "dependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@iarna/toml": "^2.2.5",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.0.6",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-progress": "^1.0.3",
    "@radix-ui/react-select": "^2.0.0",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.0.2",
    "@radix-ui/react-tabs": "^1.0.4",
    "@radix-ui/react-toast": "^1.1.5",
    "@tanstack/react-query": "^5.17.19",
    "@tanstack/react-query-devtools": "^5.17.19",
    "@tauri-apps/api": "^2.10.1",
    "axios": "^1.12.2",
    "cheerio": "^1.1.2",
    "chokidar": "^4.0.3",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "decompress": "^4.2.1",
    "decompress-unzip": "^4.0.1",
    "ffmpeg-static": "^5.2.0",
    "framer-motion": "^10.18.0",
    "librespot": "^0.2.22",
    "lucide-react": "^0.312.0",
    "music-metadata": "^11.9.0",
    "progress": "^2.0.3",
    "re-unplayplay": "^1.2.8",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-icons": "^5.6.0",
    "react-router-dom": "^6.21.3",
    "sharp": "^0.34.4",
    "tailwind-merge": "^2.2.0",
    "unzipper": "^0.12.3",
    "xml2js": "^0.6.2",
    "ytmusic-api": "^5.3.0",
    "zustand": "^4.5.0"
  }
}
