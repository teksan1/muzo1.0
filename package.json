{
  "name": "mediaharbor",
  "version": "1.1.9",
  "scripts": {
    "postinstall": "node scripts/patch-librespot.js && patch-package",
    "dev": "vite",
    "build:react": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint . --report-unused-disable-directives --max-warnings 0",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "test": "vitest",
    "tauri:icon": "npx tauri icon src/assets/MediaHarbor_Logo.svg -o src/app/icons",
    "tauri:dev": "concurrently \"npx vite dev\" \"cd src/app && cargo tauri dev\"",
    "tauri:build": "npm run build:react && cd src/app && APPIMAGE_EXTRACT_AND_RUN=1 cargo tauri build",
    "tauri:build:linux": "npm run build:react && cd src/app && APPIMAGE_EXTRACT_AND_RUN=1 cargo tauri build --bundles deb,rpm,appimage",
    "tauri:build:win": "npm run build:react && cd src/app && cargo tauri build --bundles msi,nsis",
    "tauri:build:mac": "npm run build:react && cd src/app && cargo tauri build --bundles dmg,app",
    "tauri:build:mac:x64": "npm run build:react && cd src/app && cargo tauri build --target x86_64-apple-darwin --bundles dmg",
    "tauri:build:mac:arm64": "npm run build:react && cd src/app && cargo tauri build --target aarch64-apple-darwin --bundles dmg"
  },
  "keywords": [],
  "author": "CrossyAtom46",
  "license": "GPL-3.0-or-later",
  "description": "MediaHarbor",
  "homepage": "https://mediaharbor.github.io",
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.4",
    "@tauri-apps/cli": "^2.11.0",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
"@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "@unocss/preset-icons": "^66.6.8",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "patch-package": "^8.0.1",
    "postcss": "^8.5.13",
    "prettier": "^3.8.3",
"tailwindcss": "^4.2.4",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
"vitest": "^4.1.5",
    "wait-on": "^9.0.5"
  },
  "dependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@iarna/toml": "^2.2.5",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@tanstack/react-query": "^5.100.8",
    "@tanstack/react-query-devtools": "^5.100.8",
    "@tauri-apps/api": "^2.11.0",
    "axios": "^1.15.2",
    "cheerio": "^1.2.0",
    "chokidar": "^5.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "decompress": "^4.2.1",
    "decompress-unzip": "^4.0.1",
    "ffmpeg-static": "^5.3.0",
    "framer-motion": "^12.38.0",
    "librespot": "^0.2.22",
    "lucide-react": "^1.14.0",
    "music-metadata": "^11.12.3",
    "progress": "^2.0.3",
    "re-unplayplay": "^1.2.8",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-icons": "^5.6.0",
    "react-router-dom": "^7.14.2",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3.5.0",
    "unzipper": "^0.12.3",
    "xml2js": "^0.6.2",
    "ytmusic-api": "^5.3.1",
    "zustand": "^5.0.12"
  },
  "overrides": {
    "undici": "^6.24.0",
    "encoding-sniffer": "^1.0.2"
  }
}
